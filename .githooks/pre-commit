#!/bin/bash

# Este hook bloqueia commits que modifiquem o debian/changelog mantendo uma 
# versão que já existe como uma tag no Git, evitando quebra da pipeline de release.

if ! git diff --cached --name-only | grep -q "^debian/changelog$"; then
    exit 0
fi

CHANGELOG_LINE=$(head -1 debian/changelog)
FULL_VERSION=$(echo "$CHANGELOG_LINE" | cut -d'(' -f2 | cut -d')' -f1)
UPSTREAM_VERSION=$(echo "$FULL_VERSION" | sed 's/-[0-9]*$//')
TAG_NAME="v$UPSTREAM_VERSION"

# Atualiza as tags do remoto silenciosamente para garantir precisão
git fetch --tags >/dev/null 2>&1

if git rev-parse "$TAG_NAME" >/dev/null 2>&1; then
    echo "============================================================"
    echo "ERRO DE VERSIONAMENTO: A versão $UPSTREAM_VERSION no debian/changelog"
    echo "já existe como uma tag ($TAG_NAME) neste repositório!"
    echo "============================================================"
    echo "A pipeline do GitHub Actions falhará/conflitará ao tentar criar"
    echo "um novo release com esta tag repetida."
    echo ""
    echo "Solução:"
    echo "  1. Altere debian/changelog e aumente a versão (ex: 1.0.8-1)"
    echo "  2. Adicione as mudanças em um novo bloco."
    echo "  3. Tente realizar o commit novamente."
    echo "============================================================"
    exit 1
fi

exit 0
