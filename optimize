#!/usr/bin/env bash
# optimize - hardware-aware Debian/Ubuntu package rebuilder
set -Eeuo pipefail
IFS=$'\n\t'
umask 027

readonly SCRIPT_NAME="optimize"
readonly OPTIMIZE_VERSION="2.0.0"
readonly DEFAULT_KERNEL_KEEP="drivers/net:drivers/scsi:drivers/ata:drivers/nvme:drivers/usb:drivers/md:drivers/virtio:fs:crypto:net:security"

PROFILE="native-safe"
PACKAGE=""
JOBS="$(nproc 2> /dev/null || printf '1')"
OUTPUT_DIR="$PWD/optimize-output"
SUITE=""
CHROOT_MODE="auto"
NO_CHECK=false
INSTALL=false
KEEP_BUILD=false
YES=false
KERNEL=false
CUSTOM_CFLAGS=""
CUSTOM_CXXFLAGS=""
KERNEL_KEEP="$DEFAULT_KERNEL_KEEP"

RUN_DIR=""
RECORD_DIR=""
DSC=""
SOURCE_NAME=""
SOURCE_VERSION=""
USED_PROFILE=""
BUILD_ID=""
DISTRO_BASE=""
DISTRO_NAME=""
ARCH=""
MIRROR=""
COMPONENTS=""
SBUILD_MODE=""
SBUILD_CHROOT=""
NATIVE_FLAGS=""

declare -a ATTEMPTS=()
declare -a DEBS=()

if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
    RED=$'\e[31m'
    GREEN=$'\e[32m'
    YELLOW=$'\e[33m'
    CYAN=$'\e[36m'
    BOLD=$'\e[1m'
    NC=$'\e[0m'
else
    RED=""
    GREEN=""
    YELLOW=""
    CYAN=""
    BOLD=""
    NC=""
fi

info() { printf '%b[INFO]%b %s\n' "$CYAN" "$NC" "$*"; }
ok() { printf '%b[ OK ]%b %s\n' "$GREEN" "$NC" "$*"; }
warn() { printf '%b[WARN]%b %s\n' "$YELLOW" "$NC" "$*" >&2; }
die() {
    printf '%b[FAIL]%b %s\n' "$RED" "$NC" "$*" >&2
    exit 1
}
step() { printf '\n%b> %s%b\n' "${BOLD}${CYAN}" "$*" "$NC"; }

usage() {
    cat << EOF_USAGE
Usage:
  optimize [OPTIONS] <package>
  optimize --kernel [OPTIONS]

Profiles:
  vendor              Distribution flags unchanged
  native-safe         Preserve distribution -O level; add native CPU targeting (default)
  native-aggressive   Add -O3 plus native CPU targeting
  adaptive            Try aggressive, then safe, then vendor

Options:
  -p, --profile NAME          Build profile
  -c, --cflags FLAGS          Custom DEB_CFLAGS_APPEND (selects custom profile)
  -x, --cxxflags FLAGS        Custom DEB_CXXFLAGS_APPEND
  -j, --jobs N                Parallel jobs
  -o, --output-dir DIR        Output directory
      --suite CODENAME        Override detected suite
      --chroot-mode MODE      auto, unshare, or schroot
      --no-check              Disable package tests explicitly
      --install               Install generated packages using apt-get
      --keep-build            Preserve temporary workspace
  -y, --yes                   Accept setup prompts
  -k, --kernel                Build an experimental tailored kernel
      --kernel-keep PATHS     Extra localmodconfig LMC_KEEP paths separated by ':'
  -h, --help                  Show help
  -V, -v, --version           Show version
EOF_USAGE
}

print_version() {
    printf '%s %s\n' "$SCRIPT_NAME" "$OPTIMIZE_VERSION"
}

need_value() {
    [[ -n "${2:-}" ]] || die "$1 requires a value"
}

parse_args() {
    while (($#)); do
        case "$1" in
            -p | --profile)
                need_value "$1" "${2:-}"
                PROFILE="$2"
                shift 2
                ;;
            --profile=*)
                PROFILE="${1#*=}"
                shift
                ;;
            -c | --cflags)
                need_value "$1" "${2:-}"
                CUSTOM_CFLAGS="$2"
                shift 2
                ;;
            --cflags=*)
                CUSTOM_CFLAGS="${1#*=}"
                shift
                ;;
            -x | --cxxflags)
                need_value "$1" "${2:-}"
                CUSTOM_CXXFLAGS="$2"
                shift 2
                ;;
            --cxxflags=*)
                CUSTOM_CXXFLAGS="${1#*=}"
                shift
                ;;
            -j | --jobs)
                need_value "$1" "${2:-}"
                JOBS="$2"
                shift 2
                ;;
            --jobs=*)
                JOBS="${1#*=}"
                shift
                ;;
            -o | --output-dir)
                need_value "$1" "${2:-}"
                OUTPUT_DIR="$2"
                shift 2
                ;;
            --output-dir=*)
                OUTPUT_DIR="${1#*=}"
                shift
                ;;
            --suite)
                need_value "$1" "${2:-}"
                SUITE="$2"
                shift 2
                ;;
            --suite=*)
                SUITE="${1#*=}"
                shift
                ;;
            --chroot-mode)
                need_value "$1" "${2:-}"
                CHROOT_MODE="$2"
                shift 2
                ;;
            --chroot-mode=*)
                CHROOT_MODE="${1#*=}"
                shift
                ;;
            --no-check)
                NO_CHECK=true
                shift
                ;;
            --install)
                INSTALL=true
                shift
                ;;
            --keep-build)
                KEEP_BUILD=true
                shift
                ;;
            -y | --yes)
                YES=true
                shift
                ;;
            -k | --kernel)
                KERNEL=true
                shift
                ;;
            --kernel-keep)
                need_value "$1" "${2:-}"
                KERNEL_KEEP+=":$2"
                shift 2
                ;;
            --kernel-keep=*)
                KERNEL_KEEP+=":${1#*=}"
                shift
                ;;
            -h | --help)
                print_version
                usage
                exit 0
                ;;
            -V | -v | --version)
                print_version
                exit 0
                ;;
            -*)
                die "unknown option: $1"
                ;;
            *)
                [[ -z "$PACKAGE" ]] || die "only one package may be built"
                PACKAGE="$1"
                shift
                ;;
        esac
    done
}

validate_args() {
    [[ "$JOBS" =~ ^[1-9][0-9]*$ ]] || die "--jobs must be a positive integer"

    case "$PROFILE" in
        vendor | native-safe | native-aggressive | adaptive | custom) ;;
        *) die "invalid profile: $PROFILE" ;;
    esac

    case "$CHROOT_MODE" in
        auto | unshare | schroot) ;;
        *) die "invalid chroot mode: $CHROOT_MODE" ;;
    esac

    if [[ -n "$CUSTOM_CFLAGS$CUSTOM_CXXFLAGS" ]]; then
        [[ "$PROFILE" != "adaptive" ]] || die "adaptive cannot be combined with custom flags"
        PROFILE="custom"
    fi

    if "$KERNEL"; then
        [[ -z "$PACKAGE" ]] || die "do not combine --kernel with a package name"
    else
        [[ -n "$PACKAGE" ]] || die "no package name provided"
        [[ "$PACKAGE" =~ ^[a-z0-9][a-z0-9+.-]*(:[a-z0-9][a-z0-9-]*)?$ ]] || die "invalid Debian package name: $PACKAGE"
    fi
}

cache_root() {
    printf '%s/optimize' "${XDG_CACHE_HOME:-$HOME/.cache}"
}

cleanup() {
    local rc=$?
    trap - EXIT INT TERM

    if [[ -n "$RUN_DIR" && -d "$RUN_DIR" && "$KEEP_BUILD" == false ]]; then
        local root
        local run_real
        local root_real
        root="$(cache_root)"
        run_real="$(realpath -m -- "$RUN_DIR")"
        root_real="$(realpath -m -- "$root")"

        if [[ "$run_real" == "$root_real"/run.* ]]; then
            rm -rf --one-file-system -- "$RUN_DIR"
        else
            warn "refused unsafe cleanup path: $RUN_DIR"
        fi
    fi

    exit "$rc"
}

ask() {
    "$YES" && return 0
    [[ -t 0 ]] || return 1

    local answer
    read -r -p "$1 [y/N] " answer
    [[ "$answer" =~ ^[Yy]$ ]]
}

need_sudo() {
    command -v sudo > /dev/null || die "sudo is required"
    sudo -v || die "sudo authorization failed"
}

prepare_workspace() {
    local root
    root="$(cache_root)"
    mkdir -p "$root"
    chmod 700 "$root"
    RUN_DIR="$(mktemp -d -p "$root" run.XXXXXXXX)"
    OUTPUT_DIR="$(realpath -m -- "$OUTPUT_DIR")"
    mkdir -p "$OUTPUT_DIR"
    chmod 750 "$OUTPUT_DIR"
    BUILD_ID="$(date -u +%Y%m%dT%H%M%SZ)"
    trap cleanup EXIT INT TERM
}

detect_environment() {
    step "Detecting distribution"
    [[ -r /etc/os-release ]] || die "/etc/os-release not found"

    # shellcheck source=/dev/null
    . /etc/os-release

    DISTRO_NAME="${PRETTY_NAME:-${ID:-unknown}}"
    if [[ "${ID:-}" == "debian" ]]; then
        DISTRO_BASE="debian"
    elif [[ "${ID:-}" == "ubuntu" || " ${ID_LIKE:-} " == *" ubuntu "* ]]; then
        DISTRO_BASE="ubuntu"
    elif [[ " ${ID_LIKE:-} " == *" debian "* ]]; then
        DISTRO_BASE="debian"
    else
        die "Debian/Ubuntu base required"
    fi

    [[ -n "$SUITE" ]] || SUITE="${UBUNTU_CODENAME:-${VERSION_CODENAME:-}}"
    [[ "$SUITE" =~ ^[a-z0-9][a-z0-9.-]*$ ]] || die "unable to detect suite; use --suite"

    ARCH="$(dpkg --print-architecture)"
    if [[ "$DISTRO_BASE" == "ubuntu" ]]; then
        if [[ "$ARCH" =~ ^(amd64|i386)$ ]]; then
            MIRROR="https://archive.ubuntu.com/ubuntu"
        else
            MIRROR="https://ports.ubuntu.com/ubuntu-ports"
        fi
        COMPONENTS="main,restricted,universe,multiverse"
    else
        MIRROR="https://deb.debian.org/debian"
        COMPONENTS="main,contrib,non-free,non-free-firmware"
    fi

    ok "$DISTRO_NAME; suite=$SUITE arch=$ARCH"
}

ensure_tools() {
    local -a missing=()
    local command_name

    for command_name in apt-cache apt-get awk cc date dpkg dpkg-deb dpkg-parsechangelog dpkg-source file find make perl realpath sed sha256sum tee tr; do
        command -v "$command_name" > /dev/null || missing+=("$command_name")
    done

    if "$KERNEL"; then
        for command_name in findmnt lscpu lsmod lspci modprobe; do
            command -v "$command_name" > /dev/null || missing+=("$command_name")
        done
    else
        for command_name in sbuild sbuild-createchroot unshare; do
            command -v "$command_name" > /dev/null || missing+=("$command_name")
        done
    fi

    ((${#missing[@]} == 0)) && return

    warn "missing tools: ${missing[*]}"
    ask "Install required build tools?" || die "missing dependencies"
    need_sudo

    sudo apt-get update
    if "$KERNEL"; then
        sudo apt-get install -y --no-remove \
            bc \
            bison \
            build-essential \
            cpio \
            dwarves \
            fakeroot \
            flex \
            kmod \
            libelf-dev \
            libncurses-dev \
            libssl-dev \
            pciutils \
            rsync \
            usbutils \
            util-linux
    else
        sudo apt-get install -y --no-remove \
            build-essential \
            debootstrap \
            devscripts \
            dpkg-dev \
            file \
            sbuild \
            schroot
    fi
}

ensure_sources() {
    apt-cache showsrc apt > /dev/null 2>&1 && return

    warn "deb-src indexes are unavailable"
    ask "Enable deb-src in active APT sources?" || die "deb-src repositories are required"
    need_sudo

    local backup
    local changed=false
    local f
    local tmp
    backup="/var/backups/optimize/apt-sources/$(date -u +%Y%m%dT%H%M%SZ)"
    sudo mkdir -p "$backup"

    shopt -s nullglob
    for f in /etc/apt/sources.list.d/*.sources; do
        tmp="$RUN_DIR/$(basename "$f")"
        awk '/^Types:/ && $0 !~ /deb-src/ && $0 ~ /deb/ {$0=$0" deb-src"} {print}' "$f" > "$tmp"
        if ! cmp -s "$f" "$tmp"; then
            sudo cp -a "$f" "$backup/"
            sudo install -m 644 "$tmp" "$f"
            changed=true
        fi
    done

    # shellcheck disable=SC2094
    for f in /etc/apt/sources.list /etc/apt/sources.list.d/*.list; do
        [[ -f "$f" ]] || continue
        tmp="$RUN_DIR/$(basename "$f").list"
        cp "$f" "$tmp"
        while IFS= read -r line; do
            [[ "$line" =~ ^[[:space:]]*deb[[:space:]] ]] || continue
            local src
            src="$(sed -E 's/^([[:space:]]*)deb([[:space:]])/\1deb-src\2/' <<< "$line")"
            grep -Fqx "$src" "$f" || printf '\n%s\n' "$src" >> "$tmp"
        done < "$f"

        if ! cmp -s "$f" "$tmp"; then
            sudo cp -a "$f" "$backup/"
            sudo install -m 644 "$tmp" "$f"
            changed=true
        fi
    done
    shopt -u nullglob

    "$changed" || die "no source entry could be enabled"
    sudo apt-get update
    apt-cache showsrc apt > /dev/null 2>&1 || die "source indexes still unavailable"
    ok "APT source backup: $backup"
}

detect_native_flags() {
    local mode="${1:-required}"
    local candidate
    local log_file
    local -a words=()

    log_file="$RUN_DIR/native-flags.log"
    : > "$log_file"

    for candidate in "-march=native -pipe" "-mcpu=native -pipe" "-mtune=native -pipe"; do
        read -r -a words <<< "$candidate"
        printf 'testing: %s\n' "$candidate" >> "$log_file"
        if printf 'int main(void){return 0;}\n' | cc -x c - -c -o "$RUN_DIR/native-test.o" "${words[@]}" >> "$log_file" 2>&1; then
            NATIVE_FLAGS="$candidate"
            ok "native flags: $NATIVE_FLAGS"
            return
        fi
        printf '\n' >> "$log_file"
    done

    NATIVE_FLAGS=""
    if [[ "$mode" == "optional" ]]; then
        warn "compiler did not accept native CPU target flags; continuing without them (use --keep-build to preserve $log_file)"
        return 1
    fi

    die "compiler has no supported native-target flag (see $log_file)"
}

select_chroot() {
    step "Selecting sbuild backend"

    local cache
    local schroot_name
    local schroot_ok=false
    local tarball=""
    local unshare_ok=false

    cache="${XDG_CACHE_HOME:-$HOME/.cache}/sbuild"
    mkdir -p "$cache"
    schroot_name="$SUITE-$ARCH-sbuild"

    for candidate in "$cache/$SUITE-$ARCH.tar.zst" "$cache/$SUITE-$ARCH.tar.xz" "$cache/$SUITE-$ARCH.tar.gz"; do
        [[ -f "$candidate" ]] || continue
        tarball="$candidate"
        break
    done

    if sbuild --help 2>&1 | grep -q unshare && unshare -Ur true > /dev/null 2>&1; then
        unshare_ok=true
    fi

    if command -v schroot > /dev/null && schroot -l 2> /dev/null | grep -Fxq "chroot:$schroot_name"; then
        schroot_ok=true
    fi

    if [[ "$CHROOT_MODE" == "unshare" && "$unshare_ok" != true ]]; then
        die "unshare chroot mode requested but unavailable"
    fi

    if [[ "$CHROOT_MODE" == "schroot" && "$schroot_ok" != true ]]; then
        need_sudo
        sudo sbuild-createchroot \
            --chroot-mode=schroot \
            --arch="$ARCH" \
            --components="$COMPONENTS" \
            "$SUITE" \
            "/srv/chroot/$schroot_name" \
            "$MIRROR"
        SBUILD_MODE="schroot"
        SBUILD_CHROOT="$schroot_name"
        ok "$SBUILD_MODE ($SBUILD_CHROOT)"
        return
    fi

    if [[ "$CHROOT_MODE" != "schroot" && -n "$tarball" && "$unshare_ok" == true ]]; then
        SBUILD_MODE="unshare"
        SBUILD_CHROOT="$tarball"
    elif [[ "$CHROOT_MODE" != "unshare" && "$schroot_ok" == true ]]; then
        SBUILD_MODE="schroot"
        SBUILD_CHROOT="$schroot_name"
    elif [[ "$CHROOT_MODE" != "schroot" && "$unshare_ok" == true ]]; then
        tarball="$cache/$SUITE-$ARCH.tar.gz"
        sbuild-createchroot \
            --chroot-mode=unshare \
            --arch="$ARCH" \
            --components="$COMPONENTS" \
            --make-sbuild-tarball="$tarball" \
            "$SUITE" \
            "$RUN_DIR/chroot" \
            "$MIRROR"
        SBUILD_MODE="unshare"
        SBUILD_CHROOT="$tarball"
    else
        need_sudo
        sudo sbuild-createchroot \
            --chroot-mode=schroot \
            --arch="$ARCH" \
            --components="$COMPONENTS" \
            "$SUITE" \
            "/srv/chroot/$schroot_name" \
            "$MIRROR"
        SBUILD_MODE="schroot"
        SBUILD_CHROOT="$schroot_name"
    fi

    ok "$SBUILD_MODE ($SBUILD_CHROOT)"
}

profile_flags() {
    case "$1" in
        vendor) printf '' ;;
        native-safe) printf '%s' "$NATIVE_FLAGS" ;;
        native-aggressive) printf '%s' "-O3 $NATIVE_FLAGS" ;;
        custom) printf '%s' "$CUSTOM_CFLAGS" ;;
        *) die "cannot resolve flags for profile: $1" ;;
    esac
}

profile_suffix() {
    printf '%s' "$1" | tr -cd '[:alnum:]'
}

profile_version() {
    local suffix
    suffix="$(profile_suffix "$1")"
    printf '%s+opt2.%s.%s' "$SOURCE_VERSION" "$suffix" "$BUILD_ID"
}

perl_quote() {
    local value="$1"
    value="${value//\\/\\\\}"
    value="${value//\'/\\\'}"
    printf '%s' "$value"
}

write_sbuild_config() {
    local profile="$1"
    local file="$2"
    local cflags
    local cxxflags
    local user_config=""

    cflags="$(profile_flags "$profile")"
    cxxflags="$cflags"
    if [[ "$profile" == "custom" ]]; then
        cxxflags="${CUSTOM_CXXFLAGS:-$cflags}"
    fi

    if [[ -r "$HOME/.config/sbuild/config.pl" ]]; then
        user_config="$HOME/.config/sbuild/config.pl"
    elif [[ -r "$HOME/.sbuildrc" ]]; then
        user_config="$HOME/.sbuildrc"
    fi

    {
        printf '# temporary optimize configuration\n'
        if [[ -n "$user_config" ]]; then
            printf "do '%s';\n" "$(perl_quote "$user_config")"
        fi
        printf "our \$build_environment;\n"
        printf "\$build_environment ||= {};\n"
        if [[ -n "$cflags" ]]; then
            printf "\$build_environment->{'DEB_CFLAGS_APPEND'} = '%s';\n" "$(perl_quote "$cflags")"
            printf "\$build_environment->{'DEB_FFLAGS_APPEND'} = '%s';\n" "$(perl_quote "$cflags")"
            printf "\$build_environment->{'DEB_FCFLAGS_APPEND'} = '%s';\n" "$(perl_quote "$cflags")"
            printf "\$build_environment->{'DEB_OBJCFLAGS_APPEND'} = '%s';\n" "$(perl_quote "$cflags")"
        fi
        if [[ -n "$cxxflags" ]]; then
            printf "\$build_environment->{'DEB_CXXFLAGS_APPEND'} = '%s';\n" "$(perl_quote "$cxxflags")"
            printf "\$build_environment->{'DEB_OBJCXXFLAGS_APPEND'} = '%s';\n" "$(perl_quote "$cxxflags")"
        fi
        if "$NO_CHECK"; then
            printf "\$build_environment->{'DEB_BUILD_OPTIONS'} = 'nocheck';\n"
            printf "\$build_environment->{'DEB_BUILD_PROFILES'} = 'nocheck';\n"
        fi
        printf "\$build_environment->{'LC_ALL'} = 'C.UTF-8';\n"
        printf "1;\n"
    } > "$file"

    perl -c "$file" > /dev/null
}

download_source() {
    step "Downloading official source"

    local dl
    local -a dsc_files=()

    dl="$RUN_DIR/source"
    mkdir "$dl"
    cd "$dl"
    apt-get source --download-only -- "$PACKAGE"

    mapfile -t dsc_files < <(find "$dl" -maxdepth 1 -name '*.dsc' -type f | sort)
    ((${#dsc_files[@]} == 1)) || die "expected exactly one .dsc file"

    DSC="${dsc_files[0]}"
    SOURCE_NAME="$(sed -n 's/^Source:[[:space:]]*//p' "$DSC" | head -n 1)"
    SOURCE_VERSION="$(sed -n 's/^Version:[[:space:]]*//p' "$DSC" | head -n 1)"
    [[ -n "$SOURCE_NAME" && -n "$SOURCE_VERSION" ]] || die "could not read source metadata from .dsc"

    RECORD_DIR="$OUTPUT_DIR/${SOURCE_NAME}_${SOURCE_VERSION}_${BUILD_ID}"
    mkdir -p "$RECORD_DIR/attempts" "$RECORD_DIR/artifacts"
    ok "$SOURCE_NAME $SOURCE_VERSION"
}

prepend_changelog() {
    local src_dir="$1"
    local profile="$2"
    local version
    local changelog
    local tmp
    local maint_name
    local maint_email

    version="$(profile_version "$profile")"
    changelog="$src_dir/debian/changelog"
    tmp="$(mktemp "$src_dir/debian/changelog.XXXXXX")"
    maint_name="${DEBFULLNAME:-optimize local rebuild}"
    maint_email="${DEBEMAIL:-optimize@localhost}"

    {
        printf '%s (%s) %s; urgency=medium\n\n' "$SOURCE_NAME" "$version" "$SUITE"
        printf '  * Local optimize rebuild using profile %s.\n\n' "$profile"
        printf ' -- %s <%s>  %s\n\n' "$maint_name" "$maint_email" "$(date -R)"
        cat "$changelog"
    } > "$tmp"

    mv "$tmp" "$changelog"
}

attempt_build() {
    local profile="$1"
    local attempt_dir
    local build_dir
    local cfg
    local flags
    local rc
    local src_dir
    local version
    local -a cmd=()

    attempt_dir="$RECORD_DIR/attempts/$profile"
    src_dir="$attempt_dir/source"
    build_dir="$attempt_dir/build"
    cfg="$attempt_dir/sbuildrc"
    mkdir -p "$attempt_dir" "$build_dir"

    dpkg-source -x "$DSC" "$src_dir" > "$attempt_dir/dpkg-source.log"
    prepend_changelog "$src_dir" "$profile"
    write_sbuild_config "$profile" "$cfg"

    version="$(profile_version "$profile")"
    flags="$(profile_flags "$profile")"
    cmd=(
        sbuild
        --dist="$SUITE"
        --arch="$ARCH"
        --chroot-mode="$SBUILD_MODE"
        --chroot="$SBUILD_CHROOT"
        --build-dir="$build_dir"
        --jobs="$JOBS"
        --apt-update
        --arch-all
        --source
        --purge=always
        --no-run-lintian
    )
    "$NO_CHECK" && cmd+=(--profiles=nocheck)
    [[ "$SBUILD_MODE" == "unshare" ]] && cmd+=(--no-enable-network)
    cmd+=("$src_dir")

    step "Build profile: $profile"
    set +e
    SBUILD_CONFIG="$cfg" "${cmd[@]}" 2>&1 | tee "$attempt_dir/console.log"
    rc=${PIPESTATUS[0]}
    set -e

    ATTEMPTS+=("$profile|$rc|$version|$flags")
    if ((rc == 0)); then
        USED_PROFILE="$profile"
        return 0
    fi

    return "$rc"
}

build_package() {
    local -a profiles=()
    local profile

    if [[ "$PROFILE" == "adaptive" ]]; then
        if [[ -n "$NATIVE_FLAGS" ]]; then
            profiles=(native-aggressive native-safe vendor)
        else
            warn "native CPU target flags unavailable; adaptive profile will use vendor flags"
            profiles=(vendor)
        fi
    else
        profiles=("$PROFILE")
    fi

    for profile in "${profiles[@]}"; do
        if attempt_build "$profile"; then
            return 0
        fi
        [[ "$PROFILE" == "adaptive" ]] && warn "falling back after failed profile: $profile"
    done

    return 1
}

collect_artifacts() {
    local attempt_dir

    attempt_dir="$RECORD_DIR/attempts/$USED_PROFILE"
    find "$attempt_dir" -maxdepth 4 -type f \( \
        -name '*.build' -o \
        -name '*.buildinfo' -o \
        -name '*.changes' -o \
        -name '*.deb' -o \
        -name '*.dsc' \
        \) -exec cp -a {} "$RECORD_DIR/artifacts/" \;

    mapfile -t DEBS < <(find "$RECORD_DIR/artifacts" -maxdepth 1 -name '*.deb' -type f | sort)
    ((${#DEBS[@]} > 0)) || die "no .deb produced"
}

yaml_quote() {
    local value="$1"
    value="${value//\\/\\\\}"
    value="${value//\"/\\\"}"
    value="${value//$'\n'/\\n}"
    printf '"%s"' "$value"
}

write_manifest() {
    local manifest
    local attempt
    local cpu
    local deb

    manifest="$RECORD_DIR/manifest.yaml"
    cpu="$(lscpu 2> /dev/null | awk -F: '/Model name/{sub(/^ +/,"",$2); print $2; exit}')"

    {
        printf 'tool: %s\n' "$(yaml_quote "$SCRIPT_NAME")"
        printf 'version: %s\n' "$(yaml_quote "$OPTIMIZE_VERSION")"
        printf 'package: %s\n' "$(yaml_quote "${PACKAGE:-kernel}")"
        printf 'source: %s\n' "$(yaml_quote "$SOURCE_NAME")"
        printf 'source_version: %s\n' "$(yaml_quote "$SOURCE_VERSION")"
        printf 'requested_profile: %s\n' "$(yaml_quote "$PROFILE")"
        printf 'used_profile: %s\n' "$(yaml_quote "$USED_PROFILE")"
        printf 'tests: %s\n' "$(yaml_quote "$("$NO_CHECK" && printf disabled-by-user || printf enabled)")"
        printf 'suite: %s\n' "$(yaml_quote "$SUITE")"
        printf 'architecture: %s\n' "$(yaml_quote "$ARCH")"
        printf 'chroot_mode: %s\n' "$(yaml_quote "$SBUILD_MODE")"
        printf 'build_id: %s\n' "$(yaml_quote "$BUILD_ID")"
        printf 'host_kernel: %s\n' "$(yaml_quote "$(uname -r)")"
        printf 'cpu: %s\n' "$(yaml_quote "$cpu")"
        printf 'attempts:\n'
        for attempt in "${ATTEMPTS[@]}"; do
            IFS='|' read -r attempt_profile attempt_rc attempt_version attempt_flags <<< "$attempt"
            printf '  - profile: %s\n' "$(yaml_quote "$attempt_profile")"
            printf '    exit_code: %s\n' "$attempt_rc"
            printf '    version: %s\n' "$(yaml_quote "$attempt_version")"
            printf '    flags: %s\n' "$(yaml_quote "$attempt_flags")"
        done
        printf 'artifacts:\n'
        for deb in "${DEBS[@]}"; do
            printf '  - file: %s\n' "$(yaml_quote "$(basename "$deb")")"
            printf '    package: %s\n' "$(yaml_quote "$(dpkg-deb -f "$deb" Package)")"
            printf '    version: %s\n' "$(yaml_quote "$(dpkg-deb -f "$deb" Version)")"
            printf '    architecture: %s\n' "$(yaml_quote "$(dpkg-deb -f "$deb" Architecture)")"
            printf '    sha256: %s\n' "$(yaml_quote "$(sha256sum "$deb" | awk '{print $1}')")"
        done
    } > "$manifest"
}

install_debs() {
    "$INSTALL" || return
    need_sudo
    sudo apt-get install -y --no-remove "${DEBS[@]}"
}

normalize_kernel_source() {
    local source="$1"

    source="${source%% *}"
    source="${source#src:}"

    case "$source" in
        linux-signed | linux-signed-amd64 | linux-signed-arm64 | linux-signed-i386 | linux-meta)
            printf 'linux'
            ;;
        linux-signed-*)
            printf 'linux-%s' "${source#linux-signed-}"
            ;;
        linux-meta-*)
            printf 'linux-%s' "${source#linux-meta-}"
            ;;
        *)
            printf '%s' "$source"
            ;;
    esac
}

source_from_binary_package() {
    local package="$1"
    local source=""

    source="$(dpkg-query -W -f='${source:Package}\n' "$package" 2> /dev/null | head -n 1 || true)"
    if [[ -z "$source" ]]; then
        source="$(apt-cache show "$package" 2> /dev/null | awk '/^Source:/ {print $2; exit}')"
    fi

    [[ -n "$source" ]] || return 1
    normalize_kernel_source "$source"
}

resolve_kernel_source() {
    local current_kernel="$1"
    local candidate
    local source

    for candidate in "linux-headers-$current_kernel" "linux-image-$current_kernel"; do
        source="$(source_from_binary_package "$candidate" || true)"
        [[ -n "$source" ]] || continue
        if apt-cache showsrc "$source" > /dev/null 2>&1; then
            printf '%s' "$source"
            return
        fi
    done

    if apt-cache showsrc linux > /dev/null 2>&1; then
        printf 'linux'
        return
    fi

    die "could not resolve a buildable kernel source package"
}

warn_if_sudo_invocation() {
    if ((EUID == 0)) && [[ -n "${SUDO_USER:-}" ]]; then
        warn "running the whole script with sudo can leave root-owned output; prefer running ./optimize --kernel and let optimize request sudo when needed"
    fi
}

kernel_pipeline() {
    local current_kernel
    local dl
    local kernel_source
    local kernel_flags
    local kernel_profile
    local module
    local source_dir

    detect_environment
    ensure_tools
    ensure_sources
    if detect_native_flags optional; then
        kernel_flags="-O2 $NATIVE_FLAGS"
        kernel_profile="kernel-native-safe"
    else
        kernel_flags="-O2"
        kernel_profile="kernel-localmodconfig"
    fi
    need_sudo

    warn "kernel mode is experimental and does not yet use the full distribution kernel packaging flow"
    current_kernel="$(uname -r)"

    step "Preparing kernel source"
    kernel_source="$(resolve_kernel_source "$current_kernel")"
    ok "kernel source package: $kernel_source"

    sudo apt-get update
    sudo apt-get build-dep -y -o APT::Get::Remove=false -- "$kernel_source"
    sudo apt-get install -y --no-remove \
        bc \
        bison \
        build-essential \
        cpio \
        dwarves \
        fakeroot \
        flex \
        kmod \
        libelf-dev \
        libncurses-dev \
        libssl-dev \
        pciutils \
        rsync \
        usbutils \
        util-linux

    dl="$RUN_DIR/kernel"
    mkdir "$dl"
    cd "$dl"
    apt-get source -- "$kernel_source"

    source_dir=""
    for candidate in "$dl"/*; do
        [[ -d "$candidate" && -f "$candidate/Kconfig" ]] || continue
        source_dir="$candidate"
        break
    done
    [[ -n "$source_dir" ]] || die "kernel source tree not found"

    SOURCE_NAME="linux"
    SOURCE_VERSION="$(dpkg-parsechangelog -l "$source_dir/debian/changelog" -S Version 2> /dev/null || make -s -C "$source_dir" kernelversion)"
    RECORD_DIR="$OUTPUT_DIR/kernel_${BUILD_ID}"
    mkdir -p "$RECORD_DIR/hardware" "$RECORD_DIR/artifacts"

    lscpu > "$RECORD_DIR/hardware/lscpu.txt"
    lsmod > "$RECORD_DIR/hardware/lsmod.txt"
    lspci -nnk > "$RECORD_DIR/hardware/lspci.txt" || true
    findmnt --real > "$RECORD_DIR/hardware/findmnt.txt" || true
    find /sys/devices -name modalias -type f -exec cat {} \; 2> /dev/null | sort -u > "$RECORD_DIR/hardware/modaliases.txt"
    cp "$RECORD_DIR/hardware/lsmod.txt" "$RECORD_DIR/hardware/lsmod-localmodconfig.txt"

    while IFS= read -r alias; do
        while IFS= read -r module; do
            module="${module//-/_}"
            grep -qE "^${module}[[:space:]]" "$RECORD_DIR/hardware/lsmod-localmodconfig.txt" || printf '%s 0 0\n' "$module" >> "$RECORD_DIR/hardware/lsmod-localmodconfig.txt"
        done < <(modprobe --resolve-alias "$alias" 2> /dev/null || true)
    done < "$RECORD_DIR/hardware/modaliases.txt"

    cd "$source_dir"
    [[ -r "/boot/config-$current_kernel" ]] || die "running kernel config not found"
    cp "/boot/config-$current_kernel" .config
    cp .config "$RECORD_DIR/hardware/config.before"

    make olddefconfig
    make LSMOD="$RECORD_DIR/hardware/lsmod-localmodconfig.txt" LMC_KEEP="$KERNEL_KEEP" localmodconfig
    make olddefconfig

    if [[ -x scripts/config ]]; then
        scripts/config --set-str LOCALVERSION '-optimize'
        trusted="$(sed -n 's/^CONFIG_SYSTEM_TRUSTED_KEYS="\(.*\)"/\1/p' .config)"
        [[ -z "$trusted" || -e "$trusted" ]] || scripts/config --set-str SYSTEM_TRUSTED_KEYS ''
        revoked="$(sed -n 's/^CONFIG_SYSTEM_REVOCATION_KEYS="\(.*\)"/\1/p' .config)"
        [[ -z "$revoked" || -e "$revoked" ]] || scripts/config --set-str SYSTEM_REVOCATION_KEYS ''
        make olddefconfig
    fi

    cp .config "$RECORD_DIR/hardware/config.after"
    diff -u "$RECORD_DIR/hardware/config.before" "$RECORD_DIR/hardware/config.after" > "$RECORD_DIR/hardware/config.diff" || true

    step "Building tailored kernel ($kernel_flags)"
    KCFLAGS="$kernel_flags" KDEB_PKGVERSION="$(make -s kernelversion)-optimize.$(date -u +%Y%m%d%H%M%S)" make -j"$JOBS" bindeb-pkg 2>&1 | tee "$RECORD_DIR/kernel-build.log"

    find .. -maxdepth 1 -name '*.deb' -type f -exec cp -a {} "$RECORD_DIR/artifacts/" \;
    mapfile -t DEBS < <(find "$RECORD_DIR/artifacts" -name '*.deb' -type f | sort)
    ((${#DEBS[@]} > 0)) || die "kernel packages not produced"

    USED_PROFILE="$kernel_profile"
    ATTEMPTS+=("$USED_PROFILE|0|$SOURCE_VERSION|$kernel_flags")
    SBUILD_MODE="host"
    write_manifest
    install_debs
    ok "kernel packages: $RECORD_DIR/artifacts"
    warn "keep the previous kernel installed and review config.diff before reboot"
}

package_pipeline() {
    detect_environment
    ensure_tools
    ensure_sources
    case "$PROFILE" in
        native-safe | native-aggressive)
            detect_native_flags
            ;;
        adaptive)
            detect_native_flags optional || true
            ;;
    esac
    select_chroot
    download_source

    build_package || die "all allowed profiles failed; inspect $RECORD_DIR/attempts"
    collect_artifacts
    write_manifest
    install_debs

    ok "profile used: $USED_PROFILE"
    ok "output: $RECORD_DIR"
    [[ "$USED_PROFILE" == "vendor" ]] || warn "native packages are CPU-specific and not generally portable"
}

main() {
    parse_args "$@"
    validate_args
    print_version
    warn_if_sudo_invocation
    prepare_workspace

    if "$KERNEL"; then
        kernel_pipeline
    else
        package_pipeline
    fi
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
