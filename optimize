# =============================================================================
# Custom Kernel Build
# =============================================================================
build_custom_kernel() {
    log_step "$(gettext "Preparing optimized custom Kernel build...")"

    local current_kernel
    current_kernel="$(uname -r)"
    log_info "$(eval_gettext "Current Kernel: \${current_kernel}")"

    local source_pkg=""
    source_pkg="$(dpkg-query -W -f='${source:Package}\n' "linux-headers-${current_kernel}" 2>/dev/null | head -n1 || true)"
    if [[ -z "$source_pkg" ]]; then
        source_pkg="$(dpkg-query -W -f='${source:Package}\n' "linux-image-${current_kernel}" 2>/dev/null | head -n1 || true)"
    fi
    if [[ -z "$source_pkg" ]]; then
        source_pkg="$(apt-cache show "linux-headers-${current_kernel}" 2>/dev/null | awk '/^Source:/ {print $2}' | head -n1 || true)"
    fi
    if [[ -z "$source_pkg" ]]; then
        source_pkg="$(apt-cache show "linux-image-${current_kernel}" 2>/dev/null | awk '/^Source:/ {print $2}' | head -n1 || true)"
    fi
    if [[ -z "$source_pkg" ]]; then
        log_info "$(gettext "Could not determine source package automatically. Defaulting to 'linux'.")"
        source_pkg="linux"
    fi
    if [[ "$source_pkg" == *"signed"* ]]; then
        log_info "$(gettext "Signed kernel package detected. Overriding source to 'linux'.")"
        source_pkg="linux"
    fi
    log_info "$(eval_gettext "Source package: \${source_pkg}")"

    TEMP_DIR="/var/cache/optimize/build/${source_pkg}_custom"
    sudo mkdir -p "$TEMP_DIR"
    sudo chmod 777 "$TEMP_DIR"
    sudo chown "$USER" "$TEMP_DIR"
    export TEMP_DIR
    log_info "$(eval_gettext "Working directory: \${DIM}\${TEMP_DIR}\${NC}")"

    cd "$TEMP_DIR"

    # Install build dependencies on host
    log_info "$(gettext "Installing kernel build dependencies...")"
    sudo apt-get update -qq
    sudo apt-get install -y --no-remove build-essential dpkg-dev libncurses-dev bison flex libssl-dev libelf-dev bc rsync kmod cpio libdw-dev dwarves || true
    log_info "$(eval_gettext "Installing source dependencies for '\${source_pkg}'...")"
    sudo apt-get build-dep -y -o APT::Get::Remove=false "$source_pkg" || true

    log_step "$(eval_gettext "Downloading source for '\${source_pkg}'...")"
    if ! apt-get source "$source_pkg"; then
        log_error "$(gettext "Failed to download kernel source.")"
        exit 1
    fi

    # Find the extracted source directory
    local src_dir=""
    for dir in "$TEMP_DIR"/*/; do
        if [[ -f "${dir}Makefile" && -f "${dir}Kconfig" ]]; then
            src_dir="${dir%/}"
            break
        fi
    done

    if [[ -z "$src_dir" ]]; then
        log_error "$(gettext "Kernel source directory not found.")"
        exit 1
    fi

    cd "$src_dir"

    log_step "$(gettext "Configuring Kernel for Local Hardware (localmodconfig)...")"
    if [[ -f "/boot/config-${current_kernel}" ]]; then
        cp "/boot/config-${current_kernel}" .config
    elif [[ -f "/proc/config.gz" ]]; then
        zcat /proc/config.gz > .config
    else
        log_info "$(gettext "No config found in /boot or /proc. Using defconfig.")"
        make defconfig || true
    fi
    
    # Accept default for any new config options and trim modules
    set +o pipefail
    yes "" | make localmodconfig 2>/dev/null || true
    set -o pipefail

    # Disable keys requirement to avoid build failures
    if [[ -x scripts/config ]]; then
        log_info "$(gettext "Disabling Canonical trust keys for custom build...")"
        scripts/config --set-str SYSTEM_TRUSTED_KEYS "" || true
        scripts/config --set-str SYSTEM_REVOCATION_KEYS "" || true
        scripts/config --set-str CONFIG_LOCALVERSION "-optimized" || true
    fi

    # Optimization 2: KCFLAGS
    export KCFLAGS="-march=native -O2 -pipe"
    log_success "KCFLAGS = ${KCFLAGS}"

    log_step "$(gettext "Building Kernel Debian packages (This will take 15-30 mins)...")"
    local jobs
    jobs="$(nproc)"
    if ! make -j"${jobs}" bindeb-pkg; then
        log_error "$(gettext "Kernel build FAILED.")"
        exit 1
    fi

    log_success "$(gettext "Kernel build completed successfully!")"

    # Deliver
    log_step "$(gettext "Collecting built Kernel packages...")"
    local output_dir="/var/cache/optimize/archives"
    sudo mkdir -p "$output_dir"
    
    local deb_count=0
    local deb_files=()
    for deb in ../*.deb; do
        [[ -e "$deb" ]] || continue
        # Ignore dbg packages to save space
        if [[ "$deb" == *"-dbg_"* ]]; then
            continue
        fi
        local basename
        basename="$(basename "$deb")"
        sudo cp "$deb" "${output_dir}/"
        deb_files+=("$basename")
        deb_count=$((deb_count + 1))
    done

    echo ""
    echo -e "  ${GREEN}${BOLD}✨ $(eval_gettext "\${deb_count} Kernel package(s) built successfully!")${NC}"
    echo ""
    echo -e "  ${BOLD}$(gettext "Output directory:")${NC} ${output_dir}"
    for f in "${deb_files[@]}"; do
        echo -e "    ${GREEN}•${NC} ${f}"
    done
    echo ""

    read -rp "  $(gettext "Do you want to install the custom kernel now? [Y/n] ")" install_confirm
    echo ""
    if [[ ! "$install_confirm" =~ ^[Nn]$ ]]; then
        log_info "$(gettext "Installing Kernel...")"
        for f in "${deb_files[@]}"; do
            sudo dpkg -i "${output_dir}/${f}" || true
        done
        sudo apt-get install --fix-broken -y
        log_success "$(gettext "Kernel installed successfully. Please reboot to use it.")"
    fi
}

# =============================================================================
# Main
# =============================================================================
main() {
    ORIGINAL_DIR="$(pwd)"

    # Parse command-line arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -k|--kernel)
                export OPTIMIZE_KERNEL=true
                export PACKAGE="linux-kernel"
                shift ;;
            -c|--cflags)
                CUSTOM_CFLAGS="$2"; shift 2 ;;
            --cflags=*)
                CUSTOM_CFLAGS="${1#*=}"; shift ;;
            -x|--cxxflags)
                CUSTOM_CXXFLAGS="$2"; shift 2 ;;
            --cxxflags=*)
                CUSTOM_CXXFLAGS="${1#*=}"; shift ;;
            -j|--jobs)
                export DEB_BUILD_OPTIONS="parallel=$2"; shift 2 ;;
            --jobs=*)
                export DEB_BUILD_OPTIONS="parallel=${1#*=}"; shift ;;
            -h|--help)
                show_banner
                usage
                exit 0 ;;
            -V|-v|--version)
                echo "${SCRIPT_NAME} v${OPTIMIZE_VERSION}"
                exit 0 ;;
            -*)
                export unknown_opt="$1"
                log_error "$(eval_gettext "Unknown option: \${unknown_opt}")"
                echo ""
                usage
                exit 1 ;;
            *)
                if [[ -n "$PACKAGE" ]]; then
                    export prev_pkg="$PACKAGE"
                    export cur_pkg="$1"
                    log_error "$(eval_gettext "Multiple package names specified: '\${prev_pkg}' and '\${cur_pkg}'")"
                    log_error "$(gettext "Only one package can be built at a time.")"
                    exit 1
                fi
                export PACKAGE="$1"
                shift ;;
        esac
    done

    show_banner

    # Validate arguments
    if [[ -z "$PACKAGE" ]]; then
        log_error "$(gettext "No package name provided.")"
        usage
        exit 1
    fi

    # Verify sudo access
    log_info "$(gettext "Verifying sudo access...")"
    if ! sudo -v 2>/dev/null; then
        log_error "$(gettext "This script requires sudo privileges.")"
        log_error "$(gettext "Please run with a user that has sudo access.")"
        exit 1
    fi

    # Keep sudo alive in the background for long builds
    (while true; do sudo -n true 2>/dev/null; sleep 50; done) &
    local sudo_keeper_pid=$!
    # Kill the sudo keeper on exit
    trap 'kill '"$sudo_keeper_pid"' 2>/dev/null; cleanup' EXIT INT TERM

    log_info "$(eval_gettext "Building package: \${BOLD}\${PACKAGE}\${NC}")"

    # Execute the build pipeline
    if [[ "$OPTIMIZE_KERNEL" == true ]]; then
        ensure_source_repos
        build_custom_kernel
    else
        detect_environment
        ensure_source_repos
        ensure_chroot
        configure_sbuild_flags
        download_source
        build_package
        deliver_packages
    fi

    echo -e "${GREEN}${BOLD}🎉 $(gettext "All done!")${NC}"
}

main "$@"
