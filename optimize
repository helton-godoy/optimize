#!/usr/bin/env bash
# =============================================================================
# optimize — Build optimized Debian/Ubuntu packages from source
#
# A modern replacement for apt-build. Downloads, compiles, and optimizes
# Debian/Ubuntu packages with hardware-specific compiler flags (-O3,
# -march=native) using sbuild for clean, isolated builds.
#
# Compatible with Debian and all derivatives: Ubuntu, Linux Mint, Pop!_OS,
# MX Linux, Zorin OS, and others.
#
# Usage: optimize [OPTIONS] <package-name>
# =============================================================================
set -euo pipefail

# =============================================================================
# i18n (Internationalization) Setup
# =============================================================================
export TEXTDOMAIN="optimize"
# Support local development (./locale) and system installation (/usr/share/locale)
if [[ -d "$(dirname "$0")/locale" ]]; then
    TEXTDOMAINDIR="$(dirname "$0")/locale"
    export TEXTDOMAINDIR
else
    export TEXTDOMAINDIR="/usr/share/locale"
fi
. gettext.sh

# =============================================================================
# Constants
# =============================================================================
readonly OPTIMIZE_VERSION="1.0.11"
readonly SCRIPT_NAME="optimize"
readonly DEFAULT_CFLAGS="-O3 -march=native -pipe"
readonly DEFAULT_CXXFLAGS="-O3 -march=native -pipe"
readonly SBUILD_CONFIG="${HOME}/.sbuildrc"

# =============================================================================
# Terminal Colors & Logging
# =============================================================================
if [[ -t 1 ]]; then
    readonly RED='\033[0;31m'
    readonly GREEN='\033[0;32m'
    readonly YELLOW='\033[1;33m'
    readonly BLUE='\033[0;34m'
    readonly CYAN='\033[0;36m'
    readonly BOLD='\033[1m'
    readonly DIM='\033[2m'
    readonly NC='\033[0m'
else
    readonly RED='' GREEN='' YELLOW='' BLUE='' CYAN='' BOLD='' DIM='' NC=''
fi

log_info()    { echo -e "${BLUE}[INFO]${NC} $*"; }
log_success() { echo -e "${GREEN}[  OK]${NC} $*"; }
log_warn()    { echo -e "${YELLOW}[WARN]${NC} $*" >&2; }
log_error()   { echo -e "${RED}[FAIL]${NC} $*" >&2; }
log_step()    { echo -e "\n${BOLD}${CYAN}▶ $*${NC}"; }

# =============================================================================
# Global State
# =============================================================================
TEMP_DIR=""
ORIGINAL_DIR=""
PACKAGE=""
SUITE=""
ARCH=""
DISTRO_BASE=""
DISTRO_ID=""
SOURCE_DIR=""
CUSTOM_CFLAGS=""
CUSTOM_CXXFLAGS=""
OPTIMIZE_KERNEL=false

# =============================================================================
# Cleanup Trap
# =============================================================================
cleanup() {
    export exit_code=$?
    # Restore original directory
    if [[ -n "$ORIGINAL_DIR" ]]; then
        cd "$ORIGINAL_DIR" 2>/dev/null || true
    fi
    # Remove temporary build directory
    if [[ -n "$TEMP_DIR" && -d "$TEMP_DIR" ]]; then
        log_info "$(eval_gettext "Cleaning up temporary directory: \${TEMP_DIR}")"
        sudo rm -rf "$TEMP_DIR"
    fi
    if [[ $exit_code -ne 0 && $exit_code -ne 130 ]]; then
        log_error "$(eval_gettext "Script terminated with errors (exit code: \${exit_code})")"
    fi
    exit "$exit_code"
}

trap cleanup EXIT INT TERM

# =============================================================================
# Banner
# =============================================================================
show_banner() {
    local msg
    msg="$(gettext "Build optimized Debian/Ubuntu packages from source")"
    local title="optimize v${OPTIMIZE_VERSION}"
    
    local title_len=${#title}
    local msg_len=${#msg}
    
    local max_len=$title_len
    if (( msg_len > max_len )); then
        max_len=$msg_len
    fi
    
    # 2 spaces padding on the left, 2 on the right
    local inner_width=$((max_len + 4))
    
    local hline=""
    for ((i=0; i<inner_width; i++)); do
        hline="${hline}─"
    done
    
    local title_pad=$(( inner_width - 2 - title_len ))
    local msg_pad=$(( inner_width - 2 - msg_len ))
    
    local title_spaces=""
    for ((i=0; i<title_pad; i++)); do title_spaces="${title_spaces} "; done
    
    local msg_spaces=""
    for ((i=0; i<msg_pad; i++)); do msg_spaces="${msg_spaces} "; done

    echo -e "${BOLD}${CYAN}"
    echo "  ┌${hline}┐"
    echo "  │  ${title}${title_spaces}│"
    echo "  │  ${msg}${msg_spaces}│"
    echo "  └${hline}┘"
    echo -e "${NC}"
}

# =============================================================================
# OS & Architecture Detection
# =============================================================================
detect_environment() {
    log_step "$(gettext "Detecting system environment...")"

    # Ensure /etc/os-release exists
    if [[ ! -f /etc/os-release ]]; then
        log_error "$(gettext "/etc/os-release not found. Is this a Debian-based system?")"
        exit 1
    fi

    # shellcheck source=/dev/null
    . /etc/os-release
    export PRETTY_NAME
    export ID

    # Determine the base distribution
    DISTRO_ID="${ID}"
    if [[ "$ID" == "debian" ]]; then
        DISTRO_BASE="debian"
    elif [[ "$ID" == "ubuntu" ]]; then
        DISTRO_BASE="ubuntu"
    elif [[ "${ID_LIKE:-}" == *"ubuntu"* ]]; then
        DISTRO_BASE="ubuntu"
    elif [[ "${ID_LIKE:-}" == *"debian"* ]]; then
        DISTRO_BASE="debian"
    else
        export DISTRO_STR="${PRETTY_NAME:-$ID}"
        log_error "$(eval_gettext "Unsupported distribution: \${DISTRO_STR}")"
        log_error "$(gettext "This tool requires a Debian or Ubuntu-based system.")"
        exit 1
    fi

    # Get the correct upstream suite codename
    # Priority: UBUNTU_CODENAME > VERSION_CODENAME > lsb_release
    if [[ -n "${UBUNTU_CODENAME:-}" ]]; then
        SUITE="$UBUNTU_CODENAME"
    elif [[ -n "${VERSION_CODENAME:-}" ]]; then
        SUITE="$VERSION_CODENAME"
    elif command -v lsb_release &>/dev/null; then
        SUITE="$(lsb_release -cs)"
    else
        log_error "$(gettext "Cannot determine distribution codename.")"
        log_error "$(gettext "Neither VERSION_CODENAME nor lsb_release are available.")"
        exit 1
    fi

    # Validate codename is not empty or "n/a"
    if [[ -z "$SUITE" || "$SUITE" == "n/a" ]]; then
        export SUITE
        log_error "$(eval_gettext "Distribution codename is invalid: '\${SUITE}'")"
        exit 1
    fi

    # Architecture — sbuild uses Debian arch names (amd64, arm64, etc.)
    if ! command -v dpkg &>/dev/null; then
        log_error "$(gettext "'dpkg' not found. Is this a Debian-based system?")"
        exit 1
    fi
    ARCH="$(dpkg --print-architecture)"

    export DISTRO_BASE DISTRO_ID SUITE ARCH
    export DISTRO_STR="${PRETTY_NAME:-$DISTRO_ID}"
    log_success "$(eval_gettext "Distribution: \${DISTRO_STR}")"
    log_success "$(eval_gettext "Base: \${DISTRO_BASE} | ID: \${DISTRO_ID} | Suite: \${SUITE} | Arch: \${ARCH}")"
}



# =============================================================================
# Source Repository Detection (deb-src)
# =============================================================================
ensure_source_repos() {
    log_step "$(gettext "Checking source repositories (deb-src)...")"

    local sources_enabled=false

    # --- Check DEB822 format (.sources files) ---
    local deb822_files
    deb822_files=(/etc/apt/sources.list.d/*.sources)

    if [[ -e "${deb822_files[0]:-}" ]]; then
        for f in "${deb822_files[@]}"; do
            if grep -qE '^Types:.*deb-src' "$f" 2>/dev/null; then
                sources_enabled=true
                break
            fi
        done

        if [[ "$sources_enabled" == false ]]; then
            # Also check sources.list (legacy and DEB822 formats) and .list files
            if [[ -f /etc/apt/sources.list ]]; then
                if grep -qE '^\s*deb-src\s' /etc/apt/sources.list 2>/dev/null \
                    || grep -qE '^Types:.*deb-src' /etc/apt/sources.list 2>/dev/null; then
                    sources_enabled=true
                fi
            fi
            if [[ "$sources_enabled" == false ]]; then
                for f in /etc/apt/sources.list.d/*.list; do
                    [[ -e "$f" ]] || continue
                    if grep -qE '^\s*deb-src\s' "$f" 2>/dev/null; then
                        sources_enabled=true
                        break
                    fi
                done
            fi
        fi

        if [[ "$sources_enabled" == true ]]; then
            log_success "$(gettext "Source repositories are enabled.")"
            return
        fi

        log_warn "$(gettext "Source repositories (deb-src) are not enabled.")"
        log_info "$(gettext "DEB822 format detected in sources configuration.")"
        echo ""
        read -rp "  $(gettext "Allow modifying apt sources to add deb-src? [y/N] ")" confirm
        echo ""
        if [[ "$confirm" =~ ^[Yy]$ ]]; then
            for f in "${deb822_files[@]}"; do
                if grep -qE '^Types:\s*deb\s*$' "$f"; then
                    sudo sed -i 's/^Types:\s*deb\s*$/Types: deb deb-src/' "$f"
                    f_base="$(basename "$f")"
                    export f_base
                    log_success "$(eval_gettext "Enabled deb-src in \${f_base}")"
                fi
            done
            sudo apt-get update -qq
        else
            log_error "$(gettext "Cannot proceed without source repositories.")"
            log_error "$(gettext "Enable deb-src manually and try again.")"
            exit 1
        fi
        return
    fi

    # --- Check legacy one-line format (.list files / sources.list) ---
    if [[ -f /etc/apt/sources.list ]]; then
        if grep -qE '^\s*deb-src\s' /etc/apt/sources.list 2>/dev/null; then
            sources_enabled=true
        fi
    fi

    # Also check .list files in sources.list.d
    for f in /etc/apt/sources.list.d/*.list; do
        [[ -e "$f" ]] || continue
        if grep -qE '^\s*deb-src\s' "$f" 2>/dev/null; then
            sources_enabled=true
            break
        fi
    done

    if [[ "$sources_enabled" == false ]]; then
        log_warn "$(gettext "Source repositories (deb-src) are not enabled.")"

        # Check if there are commented-out deb-src lines we can uncomment
        if [[ -f /etc/apt/sources.list ]] \
            && grep -qE '^\s*#\s*deb-src\s' /etc/apt/sources.list; then
            echo ""
            read -rp "  $(gettext "Uncomment deb-src lines in sources.list? [y/N] ")" confirm
            echo ""
            if [[ "$confirm" =~ ^[Yy]$ ]]; then
                sudo sed -i '/^\s*#\s*deb-src/s/^\s*#\s*//' /etc/apt/sources.list
                sudo apt-get update -qq
                log_success "$(gettext "Source repositories enabled.")"
            else
                log_error "$(gettext "Cannot proceed without source repositories.")"
                log_error "$(gettext "Enable deb-src manually and try again.")"
                exit 1
            fi
        else
            log_error "$(gettext "No source repositories found and no commented deb-src")"
            log_error "$(gettext "lines detected. Please add deb-src entries manually.")"
            exit 1
        fi
    else
        log_success "$(gettext "Source repositories are enabled.")"
    fi
}

# =============================================================================
# Chroot Management
# =============================================================================
ensure_chroot() {
    log_step "$(eval_gettext "Checking sbuild chroot for \${SUITE}-\${ARCH}...")"

    export chroot_name="${SUITE}-${ARCH}-sbuild"

    # Check if chroot already exists via schroot
    if command -v schroot &>/dev/null \
        && schroot -l 2>/dev/null | grep -q "chroot:${chroot_name}"; then
        log_success "$(eval_gettext "Chroot '\${chroot_name}' already exists.")"
        return 0
    fi

    # Check if a tarball exists for unshare mode
    local tarball_dir="${HOME}/.cache/sbuild"
    if [[ -f "${tarball_dir}/${SUITE}-${ARCH}.tar.gz" ]] \
        || [[ -f "${tarball_dir}/${SUITE}-${ARCH}.tar.zst" ]] \
        || [[ -f "${tarball_dir}/${SUITE}-${ARCH}.tar.xz" ]]; then
        log_success "$(eval_gettext "Chroot tarball found for \${SUITE}-\${ARCH}.")"
        return 0
    fi

    # Also check legacy tarball location
    if [[ -f "/var/lib/sbuild/${SUITE}-${ARCH}.tar.gz" ]] \
        || [[ -f "/var/lib/sbuild/${SUITE}-${ARCH}.tar.xz" ]]; then
        log_success "$(eval_gettext "Chroot tarball found for \${SUITE}-\${ARCH} (system-wide).")"
        return 0
    fi

    log_warn "$(eval_gettext "No chroot found for \${SUITE}-\${ARCH}.")"
    log_info "$(gettext "Creating a new sbuild chroot (this may take several minutes)...")"
    echo ""

    if [[ "$DISTRO_BASE" == "ubuntu" ]] && command -v mk-sbuild &>/dev/null; then
        # mk-sbuild handles mirror selection and schroot config automatically
        mk-sbuild "$SUITE"
    else
        # Use sbuild-createchroot for Debian and fallback
        local mirror
        if [[ "$DISTRO_BASE" == "ubuntu" ]]; then
            mirror="http://archive.ubuntu.com/ubuntu"
        else
            mirror="http://deb.debian.org/debian"
        fi

        local tarball="/var/lib/sbuild/${SUITE}-${ARCH}.tar.gz"
        sudo mkdir -p /var/lib/sbuild

        sudo sbuild-createchroot \
            --make-sbuild-tarball="$tarball" \
            --components=main,restricted,universe,multiverse \
            "$SUITE" \
            "/srv/chroot/${chroot_name}" \
            "$mirror"
    fi

    log_success "$(eval_gettext "Chroot created for \${SUITE}-\${ARCH}.")"
}

# =============================================================================
# Optimization Flags Configuration
# =============================================================================
configure_sbuild_flags() {
    log_step "$(gettext "Configuring optimization flags...")"

    local cflags="${CUSTOM_CFLAGS:-$DEFAULT_CFLAGS}"
    local cxxflags="${CUSTOM_CXXFLAGS:-$DEFAULT_CXXFLAGS}"

    # Markers to identify our managed block in .sbuildrc
    local marker_start="# >>> optimize optimization flags >>>"
    local marker_end="# <<< optimize optimization flags <<<"

    # Ensure nocheck is always included in DEB_BUILD_OPTIONS
    # Running test suites with aggressive compiler optimizations (-O3, -march=native)
    # often leads to false positives and build failures.
    if [[ -z "${DEB_BUILD_OPTIONS:-}" ]]; then
        export DEB_BUILD_OPTIONS="nocheck"
    elif [[ "$DEB_BUILD_OPTIONS" != *"nocheck"* ]]; then
        export DEB_BUILD_OPTIONS="${DEB_BUILD_OPTIONS} nocheck"
    fi

    # Build the Perl config block
    local config_block
    config_block=$(cat <<PERL
${marker_start}
# Auto-generated by optimize v${OPTIMIZE_VERSION} — do not edit manually.
# These flags are injected into the sbuild environment to compile
# packages with hardware-specific optimizations.
\$build_environment = {
    'DEB_CFLAGS_APPEND'   => '${cflags}',
    'DEB_CXXFLAGS_APPEND' => '${cxxflags}',
    'DEB_BUILD_OPTIONS'   => '${DEB_BUILD_OPTIONS}',
};
${marker_end}
PERL
)

    if [[ -f "$SBUILD_CONFIG" ]]; then
        # Remove old optimize block if present
        if grep -qF "$marker_start" "$SBUILD_CONFIG"; then
            # Use awk to remove the block (more reliable than sed for multi-line)
            local tmpfile
            tmpfile="$(mktemp)"
            awk -v start="$marker_start" -v end="$marker_end" '
                $0 == start { skip=1; next }
                $0 == end   { skip=0; next }
                !skip
            ' "$SBUILD_CONFIG" > "$tmpfile"
            mv "$tmpfile" "$SBUILD_CONFIG"
        fi
        # Append new block
        echo "" >> "$SBUILD_CONFIG"
        echo "$config_block" >> "$SBUILD_CONFIG"
    else
        # Create new .sbuildrc
        echo "$config_block" > "$SBUILD_CONFIG"
    fi

    log_success "CFLAGS  = ${cflags}"
    log_success "CXXFLAGS = ${cxxflags}"
}

# =============================================================================
# Source Download
# =============================================================================
download_source() {
    log_step "$(eval_gettext "Downloading source for '\${PACKAGE}'...")"

    TEMP_DIR="/var/cache/optimize/build/${PACKAGE}"
    sudo mkdir -p "$TEMP_DIR"
    sudo chmod 777 "$TEMP_DIR"
    sudo chown "$USER" "$TEMP_DIR"
    export TEMP_DIR
    log_info "$(eval_gettext "Working directory: \${DIM}\${TEMP_DIR}\${NC}")"

    cd "$TEMP_DIR"

    if ! apt-get source "$PACKAGE"; then
        log_error "$(eval_gettext "Failed to download source for '\${PACKAGE}'.")"
        log_error "$(gettext "Please verify:")"
        log_error "$(gettext "  • The package name is correct")"
        log_error "$(gettext "  • Source repositories (deb-src) are enabled")"
        log_error "$(gettext "  • You have an internet connection")"
        exit 1
    fi

    # Find the extracted source directory (contains debian/ subdirectory)
    SOURCE_DIR=""
    for dir in "$TEMP_DIR"/*/; do
        if [[ -d "${dir}debian" ]]; then
            SOURCE_DIR="${dir%/}"
            break
        fi
    done

    if [[ -z "$SOURCE_DIR" ]]; then
        log_error "$(gettext "Source directory not found or missing debian/ directory.")"
        log_error "$(gettext "The package may not have a standard Debian source layout.")"
        exit 1
    fi

    SOURCE_DIR_BASE="$(basename "$SOURCE_DIR")"
    export SOURCE_DIR_BASE
    log_success "$(eval_gettext "Source downloaded: \${BOLD}\${SOURCE_DIR_BASE}\${NC}")"
}

# =============================================================================
# Package Build
# =============================================================================
build_package() {
    log_step "$(eval_gettext "Building '\${PACKAGE}' in isolated chroot...")"

    export cflags="${CUSTOM_CFLAGS:-$DEFAULT_CFLAGS}"

    echo -e "  ${DIM}$(gettext "Distribution"): ${SUITE}${NC}"
    echo -e "  ${DIM}$(gettext "Architecture"): ${ARCH}${NC}"
    echo -e "  ${DIM}CFLAGS      : ${cflags}${NC}"
    echo -e "  ${DIM}$(gettext "Source")      : ${SOURCE_DIR_BASE}${NC}"
    echo ""

    log_warn "$(gettext "This may take a while depending on the package complexity.")"
    echo ""

    cd "$SOURCE_DIR"

    if ! sbuild \
        -d "$SUITE" \
        --arch="$ARCH" \
        --chroot-mode=schroot \
        --no-run-lintian \
        --no-clean-source \
        -A; then
        log_error "$(eval_gettext "Build FAILED for '\${PACKAGE}'.")"
        log_error "$(gettext "Review the build log above for details.")"
        exit 1
    fi

    log_success "$(gettext "Build completed successfully!")"
}

# =============================================================================
# Package Delivery
# =============================================================================
deliver_packages() {
    log_step "$(gettext "Collecting built packages...")"

    export output_dir="/var/cache/optimize/archives"
    sudo mkdir -p "$output_dir"
    export deb_count=0
    local deb_files=()

    # sbuild places .deb files in the parent of the source directory
    for deb in "$TEMP_DIR"/*.deb; do
        [[ -e "$deb" ]] || continue
        local basename
        basename="$(basename "$deb")"
        sudo cp "$deb" "${output_dir}/"
        deb_files+=("$basename")
        deb_count=$((deb_count + 1))
    done

    if [[ $deb_count -eq 0 ]]; then
        log_error "$(gettext "No .deb files were produced by the build.")"
        log_error "$(gettext "Check the build output above for errors.")"
        exit 1
    fi

    echo ""
    echo -e "  ${GREEN}${BOLD}✨ $(eval_gettext "\${deb_count} package(s) built successfully!")${NC}"
    echo ""
    echo -e "  ${BOLD}$(gettext "Output directory:")${NC} ${output_dir}"
    echo ""

    echo -e "  ${BOLD}$(gettext "Built packages:")${NC}"
    for f in "${deb_files[@]}"; do
        echo -e "    ${GREEN}•${NC} ${f}"
    done

    echo ""
    echo ""
    read -rp "  $(gettext "Do you want to install the generated packages now? [Y/n] ")" install_confirm
    echo ""
    if [[ ! "$install_confirm" =~ ^[Nn]$ ]]; then
        log_info "$(gettext "Installing packages...")"
        if [[ $deb_count -eq 1 ]]; then
            sudo dpkg --force-overwrite -i "${output_dir}/${deb_files[0]}" || true
        else
            sudo dpkg --force-overwrite -i "${output_dir}"/*.deb || true
        fi
        # Resolve any pending dependencies automatically
        sudo apt-get install --fix-broken -y
        log_success "$(gettext "Packages installed successfully.")"
    fi
    echo ""
    echo -e "  ${YELLOW}⚠  $(gettext "These packages were compiled with -march=native.")${NC}"
    echo -e "  ${YELLOW}   $(gettext "They are optimized for THIS machine's CPU and")${NC}"
    echo -e "  ${YELLOW}   $(gettext "may not work correctly on different hardware.")${NC}"
    echo ""
}

